{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawdClock",
  "version": "../package.json",
  "identifier": "dev.piyaboy.clawdclock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "clock",
        "title": "ClawdClock",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "backgroundColor": "#000000"
      },
      {
        "label": "settings",
        "title": "ClawdClock Settings",
        "width": 900,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDRjI0Q0UxNEMzNUIzOTYKUldTV3N6Vk00VXp5WE5obkR5Z2FnSHlaZkxRdGtMOE81VkxKYVdiK0RpaGx2TStLQ3JrOGNUakwK",
      "endpoints": [
        "https://github.com/Piya-Boy/ClawdClock/releases/latest/download/latest.json"
      ]
    }
  }
}
