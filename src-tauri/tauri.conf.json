{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawdClock",
  "version": "0.1.0",
  "identifier": "dev.piyaboy.clawdclock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "clock",
        "title": "ClawdClock",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "backgroundColor": "#000000"
      },
      {
        "label": "settings",
        "title": "ClawdClock Settings",
        "width": 900,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": false,
        "visible": true,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "nsis": {
      "installerHooks": "nsis/installer-hooks.nsi"
    }
  }
}
